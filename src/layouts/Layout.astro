---
import '../../styles/globals.css';
import '@fontsource-variable/inter/wght.css';
import interWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}

const { title = '平台演示' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="font" type="font/woff2" href={interWoff2} crossorigin />
  </head>
  <body class="antialiased text-white bg-complementary min-h-screen">
    <Header />
    
    <div class="flex flex-col px-6 bg-noise sm:px-12">
      <div class="flex flex-col w-full max-w-5xl mx-auto grow pt-20">  <!-- pt-20 给 header 留空间 -->
        <main class="grow py-12">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>